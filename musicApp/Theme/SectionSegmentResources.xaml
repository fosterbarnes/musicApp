<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:musicApp.Helpers">
    <Style x:Key="SectionSegmentInactiveStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiary-brush}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeTopBrush)}" />
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeTopBrush)}" />
                        <Border Grid.Row="0"
                                Grid.Column="2"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeTopBrush)}" />
                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeLeftBrush)}" />
                        <Border Grid.Row="1"
                                Grid.Column="2"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeRightBrush)}" />
                        <Border Grid.Row="2"
                                Grid.Column="0"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeBottomBrush)}" />
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeBottomBrush)}" />
                        <Border Grid.Row="2"
                                Grid.Column="2"
                                Background="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(helpers:SectionSegmentChrome.ChromeBottomBrush)}" />
                        <Grid Grid.Row="1" Grid.Column="1">
                            <Border x:Name="Fill" Background="{StaticResource ControlBackgroundAlt-brush}" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Fill" Property="Background" Value="{StaticResource Hover-brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Fill" Property="Background" Value="{StaticResource Pressed-brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SectionSegmentActiveStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary-brush}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="1" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Border Grid.Row="0"
                                Grid.Column="1"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Border Grid.Row="0"
                                Grid.Column="2"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Border Grid.Row="1"
                                Grid.Column="2"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Border Grid.Row="2"
                                Grid.Column="0"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Border Grid.Row="2"
                                Grid.Column="1"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Border Grid.Row="2"
                                Grid.Column="2"
                                Background="{StaticResource SectionSegmentSelectedBorder-brush}" />
                        <Grid Grid.Row="1" Grid.Column="1">
                            <Border x:Name="Fill" Background="{StaticResource ThemeBrand-brush}" />
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Fill" Property="Background" Value="{StaticResource ThemeBrand-brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Fill" Property="Background" Value="{StaticResource ThemeBrand-brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
