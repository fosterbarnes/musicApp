<UserControl x:Class="musicApp.TitleBarPlus.TitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:musicApp.TitleBarPlus"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             Height="85" 
             Background="{StaticResource AppBackground-brush}"
             MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <UserControl.Resources>
        <ResourceDictionary>
            <!-- Slightly smaller media controls (prev/next) -->
            <Style x:Key="CustomSmallMediaButton" TargetType="Button" BasedOn="{StaticResource CustomMediaButton}">
                <Setter Property="Width" Value="40"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource Pill22-cr}"
                                    Width="{TemplateBinding Width}"
                                    Height="{TemplateBinding Height}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PanelBackground-brush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Generic Scalable Button Style -->
            <Style x:Key="ScalableButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="{StaticResource Border0-thk}"/>
                <Setter Property="Padding" Value="{StaticResource Zero-thk}"/>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{Binding Path=(materialDesign:ButtonAssist.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Background="{StaticResource AppBackground-brush}" 
            VerticalAlignment="Top">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Window Controls -->
            <StackPanel Grid.Column="1" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Panel.ZIndex="10">

                <!-- Minimize Button -->
                <Button x:Name="btnMinimize" 
                        Style="{StaticResource WindowControlButton}"
                        Click="BtnMinimize_Click">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16"/>
                </Button>

                <!-- Maximize/Restore Button -->
                <Button x:Name="btnMaximize" 
                        Style="{StaticResource WindowControlButton}"
                        Click="BtnMaximize_Click">
                    <materialDesign:PackIcon x:Name="iconMaximize" Kind="WindowMaximize" Width="16" Height="16"/>
                </Button>

                <!-- Close Button -->
                <Button x:Name="btnClose" 
                        Style="{StaticResource CloseButtonStyle}"
                        Click="BtnClose_Click">
                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                </Button>
            </StackPanel>

            <!-- Playback Controls -->
            <StackPanel x:Name="playbackControlsPanel"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Left"
                        Margin="{StaticResource Left20-thk}"
                        Panel.ZIndex="10">

                <!-- Previous Track Button -->
                <Button x:Name="btnPrevious" 
                        Style="{StaticResource CustomSmallMediaButton}" 
                        Foreground="{StaticResource TextPrimary-brush}"
                        Margin="0,0" 
                        Click="BtnPrevious_Click">
                    <materialDesign:PackIcon Kind="SkipPrevious" Width="20" Height="20"/>
                </Button>

                <!-- Play/Pause Button -->
                <Button x:Name="btnPlayPause" 
                        Style="{StaticResource CustomMediaButton}" 
                        Foreground="{StaticResource TextPrimary-brush}"
                        Margin="2,0" 
                        Click="BtnPlayPause_Click">
                    <materialDesign:PackIcon x:Name="iconPlayPause" Kind="Play" Width="24" Height="24"/>
                </Button>

                <!-- Next Track Button -->
                <Button x:Name="btnNext" 
                        Style="{StaticResource CustomSmallMediaButton}" 
                        Foreground="{StaticResource TextPrimary-brush}"
                        Margin="0,0" 
                        Click="BtnNext_Click">
                    <materialDesign:PackIcon Kind="SkipNext" Width="20" Height="20"/>
                </Button>
            </StackPanel>

            <!-- Volume Controls -->
            <StackPanel x:Name="volumeControlsPanel"
                        Grid.ColumnSpan="2"
                        Orientation="Horizontal" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Left"
                        Margin="{StaticResource Left180-thk}"
                        Panel.ZIndex="10">
                <!-- Volume Slider -->
                <Slider x:Name="sliderVolume" 
                        Minimum="0" 
                        Maximum="100" 
                        Value="100" 
                        VerticalAlignment="Center" 
                        ValueChanged="SliderVolume_ValueChanged"
                        Style="{StaticResource CustomVolumeSlider}"
                        Foreground="{StaticResource AccentPrimary-brush}"
                        Background="Transparent"/>

                <!-- Volume Icon Button -->
                <Border Background="Transparent" 
                        Padding="{StaticResource IconButtonPadding-thk}" 
                        VerticalAlignment="Center" 
                        Margin="5,0,0,0" 
                        MouseLeftButtonDown="IconVolume_MouseLeftButtonDown">
                    <materialDesign:PackIcon x:Name="iconVolume" Kind="VolumeHigh" Foreground="{StaticResource TextPrimary-brush}"/>
                </Border>
            </StackPanel>

            <!-- Search Bar -->
            <Border x:Name="searchBarBorder"
                    Background="{StaticResource PanelBackground-brush}"
                    BorderBrush="{StaticResource BorderDefault-brush}"
                    BorderThickness="{StaticResource Border1-thk}"
                    CornerRadius="{StaticResource Md-cr}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,140,0"
                    Padding="{StaticResource SearchBarPadding-thk}"
                    Width="150"
                    Height="28"
                    Panel.ZIndex="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon -->
                    <materialDesign:PackIcon Grid.Column="0"
                                           Kind="Magnify"
                                           Width="16"
                                           Height="16"
                                           Foreground="{StaticResource TextTertiary-brush}"
                                           VerticalAlignment="Center"
                                           Margin="{StaticResource Right6-thk}"/>

                    <!-- Search Text Box -->
                    <TextBox Grid.Column="1"
                            x:Name="txtSearch"
                            Background="Transparent"
                            BorderThickness="{StaticResource Border0-thk}"
                            Foreground="{StaticResource TextTertiary-brush}"
                            CaretBrush="{StaticResource TextPrimary-brush}"
                            FontSize="12"
                            VerticalContentAlignment="Center"
                            Padding="{StaticResource Zero-thk}"
                            VerticalAlignment="Center">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="0">
                                                <ScrollViewer x:Name="PART_ContentHost"
                                                            Margin="{TemplateBinding Padding}"
                                                            Focusable="false"
                                                            HorizontalScrollBarVisibility="Hidden"
                                                            VerticalScrollBarVisibility="Hidden"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Clear search button -->
                    <Button x:Name="btnSearchClear"
                            Grid.Column="2"
                            Style="{StaticResource CustomMediaButton}"
                            Width="20" Height="20"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0"
                            Padding="{StaticResource Zero-thk}"
                            Visibility="Collapsed"
                            Click="BtnSearchClear_Click"
                            ToolTip="Clear search">
                        <materialDesign:PackIcon Kind="Close" Width="12" Height="12" Foreground="{StaticResource TextTertiary-brush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Current Song Info Section -->
            <Border x:Name="songInfoBorder"
                    Grid.ColumnSpan="2"
                    Background="{StaticResource SurfaceOverlay-brush}"
                    CornerRadius="{StaticResource TwoXl-cr}" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Padding="{StaticResource HeaderPanelPadding-thk}"
                    Margin="{StaticResource Zero-thk}"
                    Panel.ZIndex="1">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Album Art Container -->
                    <Border Grid.Column="0"
                            Width="50" 
                            Height="50" 
                            Background="{StaticResource BorderDefault-brush}"
                            
                            CornerRadius="{StaticResource Lg-cr}" 
                            Margin="{StaticResource Right15-thk}">
                        <Border.Clip>
                            <RectangleGeometry Rect="0,0,50,50" RadiusX="5" RadiusY="5"/>
                        </Border.Clip>
                        <Image x:Name="imgAlbumArt" Stretch="UniformToFill"/>
                    </Border>

                    <!-- Song Information -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,0,19">
                            <TextBlock x:Name="txtCurrentTrack" 
                                       Text="No track selected" 
                                       Foreground="{StaticResource TextPrimary-brush}"
                                       FontWeight="Bold" 
                                       FontSize="14"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,-1">
                                <TextBlock x:Name="txtCurrentArtist" 
                                           Text="" 
                                           Foreground="{StaticResource TextTertiary-brush}"
                                           FontSize="12"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="TxtCurrentArtist_MouseLeftButtonDown">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock x:Name="txtDashSeparator" 
                                           Text=" - " 
                                           Foreground="{StaticResource TextTertiary-brush}"
                                           FontSize="12"
                                           Margin="5,0,5,0"
                                           Visibility="Collapsed"/>
                                <TextBlock x:Name="txtCurrentAlbum" 
                                           Text="" 
                                           Foreground="{StaticResource TextTertiary-brush}"
                                           FontSize="12"
                                           Cursor="Hand"
                                           MouseLeftButtonDown="TxtCurrentAlbum_MouseLeftButtonDown">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="TextDecorations" Value="Underline"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Gradient Mask to prevent text from extending under shuffle/repeat buttons -->
                    <Rectangle x:Name="textGradientMask"
                              Grid.Column="1"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Width="125"
                              Height="38"
                              Margin="{StaticResource Zero-thk}"
                              Panel.ZIndex="0">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#000A0A0A" Offset="0.0"/>
                                <GradientStop Color="#000A0A0A" Offset="0.48"/>
                                <GradientStop Color="#FF0A0A0A" Offset="0.68"/>
                                <GradientStop Color="#FF0A0A0A" Offset="0.9"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- Small solid rectangle to cover the 1-pixel gap -->
                    <Rectangle x:Name="gapCoverRectangle"
                              Grid.Column="1"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Width="5"
                              Height="38"
                              Margin="0,0,-4,0"
                              Panel.ZIndex="0"
                              Fill="{StaticResource SurfaceOverlay-brush}"/>

                    <!-- Queue Button -->
                    <Button x:Name="btnQueue" 
                            Grid.Column="1"
                            Width="35" 
                            Height="24" 
                            Style="{StaticResource ScalableButtonStyle}"
                            Background="{StaticResource QueueButton-brush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource QueueButtonBorder-brush}"
                            materialDesign:ButtonAssist.CornerRadius="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,-83,0"
                            Panel.ZIndex="1"
                            Click="BtnQueue_Click">
                        <Image Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image.Source>
                                <StaticResource ResourceKey="di_queue"/>
                            </Image.Source>
                        </Image>
                    </Button>

                    <!-- Seek Bar -->
                    <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,36,39,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Current Time -->
                        <TextBlock x:Name="txtCurrentTime" 
                                   Grid.Column="0"
                                   Text="0:00" 
                                   Foreground="{StaticResource TextTertiary-brush}"
                                   FontSize="11" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,8,-7"/>

                        <!-- Progress Bar -->
                        <Border Grid.Column="1"
                                Height="4" 
                                Background="{StaticResource BorderDefault-brush}"
                                CornerRadius="{StaticResource Xs-cr}" 
                                VerticalAlignment="Center"
                                Margin="0,2,0,-7"
                                x:Name="seekBarBackground"
                                MouseLeftButtonDown="SeekBar_MouseLeftButtonDown"
                                MouseMove="SeekBar_MouseMove"
                                MouseLeftButtonUp="SeekBar_MouseLeftButtonUp"
                                MouseLeave="SeekBar_MouseLeave"
                                Cursor="Hand">
                            <Border x:Name="progressFill" 
                                    Background="{StaticResource TextPrimary-brush}"
                                    HorizontalAlignment="Left" 
                                    Width="0"/>
                        </Border>

                        <!-- Extended Clickable Area (Invisible) -->
                        <Border Grid.Column="1"
                                Height="20"
                                Background="Transparent"
                                VerticalAlignment="Center"
                                x:Name="seekBarExtendedArea"
                                MouseLeftButtonDown="SeekBar_MouseLeftButtonDown"
                                MouseMove="SeekBar_MouseMove"
                                MouseLeftButtonUp="SeekBar_MouseLeftButtonUp"
                                MouseLeave="SeekBar_MouseLeave"
                                Cursor="Hand"
                                Panel.ZIndex="-1"/>

                        <!-- Total Duration -->
                        <TextBlock x:Name="txtTotalDuration" 
                                   Grid.Column="2"
                                   Text="0:00" 
                                   Foreground="{StaticResource TextTertiary-brush}"
                                   FontSize="11" 
                                   VerticalAlignment="Center" 
                                   Margin="8,0,0,-7"/>
                    </Grid>

                    <!-- Shuffle and Repeat Buttons -->
                    <StackPanel Grid.Column="1" 
                              Orientation="Vertical" 
                              VerticalAlignment="Center" 
                              HorizontalAlignment="Right"
                              Margin="15,0,0,0">
                        <!-- Shuffle Button -->
                        <Button x:Name="btnShuffle" 
                                Width="24" 
                                Height="24" 
                                Style="{StaticResource ScalableButtonStyle}"
                                Background="Transparent" 
                                BorderThickness="{StaticResource Border0-thk}"
                                materialDesign:ButtonAssist.CornerRadius="3"
                                Margin="{StaticResource Bottom4-thk}"
                                Click="BtnShuffle_Click">
                            <Grid>
                                <!-- Animated background fill -->
                                <Rectangle x:Name="btnShuffleFill" 
                                          Fill="{StaticResource AccentPrimary-brush}"
                                          Width="0" 
                                          Height="0" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          RadiusX="3"
                                          RadiusY="3"/>

                                <materialDesign:PackIcon x:Name="iconShuffle" Kind="ShuffleVariant" Width="16" Height="16" Foreground="{StaticResource TextPrimary-brush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- Repeat Button -->
                        <Button x:Name="btnRepeat" 
                                Width="24" 
                                Height="24" 
                                Style="{StaticResource ScalableButtonStyle}"
                                Background="Transparent" 
                                BorderThickness="{StaticResource Border0-thk}"
                                materialDesign:ButtonAssist.CornerRadius="3"
                                Margin="{StaticResource Zero-thk}"
                                Click="BtnRepeat_Click">
                            <Grid>
                                <!-- Animated background fill -->
                                <Rectangle x:Name="btnRepeatFill" 
                                          Fill="{StaticResource AccentPrimary-brush}"
                                          Width="0" 
                                          Height="0" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          RadiusX="3"
                                          RadiusY="3"/>

                                <Image x:Name="iconRepeat" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <TranslateTransform x:Name="iconRepeatTransform" X="0" Y="0"/>
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl> 