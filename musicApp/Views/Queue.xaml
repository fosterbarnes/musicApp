<UserControl x:Class="musicApp.Views.QueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:musicApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="24,10,24,4"
                    HorizontalAlignment="Left">
            <Button Style="{DynamicResource MaterialDesignToolButton}"
                    materialDesign:RippleAssist.IsDisabled="True"
                    Width="32" Height="32"
                    ToolTip="Add to queue">
                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"/>
            </Button>
            <Button Style="{DynamicResource MaterialDesignToolButton}"
                    materialDesign:RippleAssist.IsDisabled="True"
                    Width="32" Height="32"
                    Margin="8,0,0,0"
                    ToolTip="Remove selected song from queue"
                    Click="QueueToolbarRemove_Click">
                <materialDesign:PackIcon Kind="Minus" Width="20" Height="20"/>
            </Button>
            <Button Style="{DynamicResource MaterialDesignToolButton}"
                    materialDesign:RippleAssist.IsDisabled="True"
                    Width="32" Height="32"
                    Margin="8,0,0,0"
                    ToolTip="Move selected song up"
                    Click="QueueToolbarMoveUp_Click">
                <materialDesign:PackIcon Kind="ChevronUp" Width="20" Height="20"/>
            </Button>
            <Button Style="{DynamicResource MaterialDesignToolButton}"
                    materialDesign:RippleAssist.IsDisabled="True"
                    Width="32" Height="32"
                    Margin="8,0,0,0"
                    ToolTip="Move selected song down"
                    Click="QueueToolbarMoveDown_Click">
                <materialDesign:PackIcon Kind="ChevronDown" Width="20" Height="20"/>
            </Button>
        </StackPanel>

        <views:TrackListView x:Name="trackList"
                             Grid.Row="1"
                             ViewName="Queue"
                             SingleClickPlays="False"
                             AllowRowReorder="True" />
    </Grid>
</UserControl>
