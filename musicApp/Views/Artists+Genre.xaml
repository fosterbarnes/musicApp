<UserControl x:Class="musicApp.Views.ArtistGenreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:musicApp.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" MinWidth="200" MaxWidth="500"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="200"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Margin="-4,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="sidebarTitle"
                       Grid.Row="0"
                       Text="Artists"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary-brush}"
                       Margin="{StaticResource Bottom20-thk}"/>
            <ListView x:Name="lstArtistsOrGenres"
                      Grid.Row="1"
                      Background="Transparent"
                      Foreground="{StaticResource TextPrimary-brush}"
                      Padding="0,0,0,18"
                      ItemContainerStyle="{StaticResource SidebarListViewItemStyle}"
                      SelectionChanged="LstArtistsOrGenres_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Style="{StaticResource CustomGridSplitter}"
                      Cursor="SizeWE"
                      ShowsPreview="False"
                      ResizeDirection="Columns"/>
        <Grid Grid.Column="2">
            <views:TrackListView x:Name="trackList"
                                  ViewName="Songs"
                                  SingleClickPlays="False"
                                  PlayTrackRequested="TrackList_PlayTrackRequested"
                                  Visibility="Collapsed"/>
            <TextBlock x:Name="placeholderText"
                       Text="Select an artist"
                       Foreground="{StaticResource TextMuted-brush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
