<UserControl x:Class="musicApp.Views.SearchPopupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:musicApp.Views"
             mc:Ignorable="d"
             d:DesignHeight="320" d:DesignWidth="380"
             Background="Transparent">
    <UserControl.Resources>
        <ContextMenu x:Key="SearchResultContextMenu" Style="{StaticResource TrackContextMenuStyle}" Opened="SearchContextMenu_Opened">
            <ContextMenu.Resources>
                <Style TargetType="Separator" BasedOn="{StaticResource TrackContextMenuSeparatorStyle}" />
            </ContextMenu.Resources>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Play Next" Click="SearchContextMenu_PlayNextClick"/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Add to Queue" Click="SearchContextMenu_AddToQueueClick"/>
            <Separator/>
            <MenuItem Style="{StaticResource TrackContextMenuItemWithSubmenuStyle}" Header="Add to Playlist" Click="SearchContextMenu_AddToPlaylistClick">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource TrackContextSubMenuItemStyle}"/>
                </MenuItem.ItemContainerStyle>
                <MenuItem Header="New Playlist" Click="SearchContextMenu_NewPlaylistClick"/>
                <Separator/>
            </MenuItem>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Show in Artists" Click="SearchContextMenu_ShowInArtistsClick"/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Show in Albums" Click="SearchContextMenu_ShowInAlbumsClick"/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Show in Songs" Click="SearchContextMenu_ShowInSongsClick"/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Show in Queue" Click="SearchContextMenu_ShowInQueueClick"/>
            <Separator/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Info" Click="SearchContextMenu_InfoClick"/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Show in Explorer" Click="SearchContextMenu_ShowInExplorerClick"/>
            <Separator/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Remove from Library" Click="SearchContextMenu_RemoveFromLibraryClick"/>
            <MenuItem Style="{StaticResource TrackContextMenuItemStyle}" Header="Delete" Click="SearchContextMenu_DeleteClick"/>
        </ContextMenu>
    </UserControl.Resources>
    <Grid SnapsToDevicePixels="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Polygon Grid.Row="0"
                 Points="0,10 10,0 20,10"
                 Fill="{StaticResource PanelBackground-brush}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Top"
                 Margin="{StaticResource SearchPopupCaratMargin-thk}"
                 Stretch="None"
                 SnapsToDevicePixels="True"/>
        <Border x:Name="PopupBorder"
                Grid.Row="1"
                Background="{StaticResource PanelBackground-brush}"
                BorderBrush="{StaticResource BorderDefault-brush}"
                BorderThickness="1,0,1,1"
                CornerRadius="0,0,6,6"
                Padding="{StaticResource PopupContentPadding-thk}"
                MinWidth="360"
                Margin="0,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer x:Name="SearchScrollViewer" Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid MinHeight="0">
                    <StackPanel x:Name="SectionsPanel">
                    <!-- Albums section (order set in code from SectionOrder) -->
                    <StackPanel x:Name="AlbumsSection">
                        <TextBlock Text="Albums" FontWeight="Bold" Foreground="{StaticResource TextPrimary-brush}" FontSize="14" Margin="{StaticResource SectionHeaderGap-thk}"/>
                        <ItemsControl x:Name="AlbumsList" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Padding="{StaticResource SearchRowPadding-thk}" Cursor="Hand" MouseLeftButtonDown="AlbumItem_MouseLeftButtonDown" ContextMenu="{StaticResource SearchResultContextMenu}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Hover-brush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" Background="{StaticResource BorderDefault-brush}" CornerRadius="2" Grid.Column="0">
                                            <Image Source="{Binding AlbumArtSource}" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="{StaticResource SearchTextOffset-thk}">
                                            <TextBlock Text="{Binding AlbumTitle}" Foreground="{StaticResource TextPrimary-brush}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}" Foreground="{StaticResource TextTertiary-brush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Artists section -->
                    <StackPanel x:Name="ArtistsSection">
                        <TextBlock Text="Artists" FontWeight="Bold" Foreground="{StaticResource TextPrimary-brush}" FontSize="14" Margin="{StaticResource SectionHeaderGap-thk}"/>
                        <ItemsControl x:Name="ArtistsList" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent" Padding="{StaticResource SearchRowPadding-thk}" Cursor="Hand" MouseLeftButtonDown="ArtistItem_MouseLeftButtonDown">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource Hover-brush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40"
                                                Height="40"
                                                Background="{StaticResource Selected-brush}"
                                                CornerRadius="20"
                                                Grid.Column="0"
                                                ClipToBounds="True">
                                            <Border.Clip>
                                                <EllipseGeometry RadiusX="20" RadiusY="20" Center="20,20"/>
                                            </Border.Clip>
                                            <Image Source="{Binding AlbumArtSource}" Stretch="UniformToFill"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="{StaticResource SearchTextOffset-thk}">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary-brush}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}" Foreground="{StaticResource TextTertiary-brush}" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Songs section -->
                    <StackPanel x:Name="SongsSection">
                        <TextBlock Text="Songs" FontWeight="Bold" Foreground="{StaticResource TextPrimary-brush}" FontSize="14" Margin="{StaticResource SectionHeaderGap-thk}"/>
                        <ItemsControl x:Name="SongsList" Margin="0,0,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:CompactSongRow Title="{Binding Title}"
                                                      Artist="{Binding Artist}"
                                                      AlbumArtSource="{Binding AlbumArtSource}"
                                                      IsNowPlaying="{Binding IsNowPlaying}"
                                                      MouseLeftButtonDown="SongItem_MouseLeftButtonDown"
                                                      ContextMenu="{StaticResource SearchResultContextMenu}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                        <TextBlock x:Name="NoResultsText" Text="No results" Foreground="{StaticResource TextMuted-brush}" FontSize="13" Margin="0,12,0,0" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Grid Grid.Row="1" Margin="0,0,0,0" Height="1" Background="{StaticResource PanelBackground-brush}">
                <Thumb x:Name="ResizeThumb"
                       Cursor="SizeNS"
                       DragDelta="ResizeThumb_DragDelta"
                       Height="13"
                       VerticalAlignment="Top"
                       Margin="0,0,0,-12"
                       IsHitTestVisible="True">
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Grid Background="Transparent">
                                <Border Height="1" Background="{StaticResource BorderStrong-brush}" VerticalAlignment="Top"/>
                            </Grid>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
            </Grid>
        </Grid>
    </Border>
    </Grid>
</UserControl>
