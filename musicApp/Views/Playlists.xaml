<UserControl x:Class="musicApp.Views.PlaylistsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:musicApp.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:musicApp.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:PinnedToStarIconKindConverter x:Key="PinnedToStarIconKindConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="200" MaxWidth="500"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="200"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0" Margin="-4,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Text="Playlists"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimary-brush}"
                       Margin="{StaticResource Bottom20-thk}"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="26,0,0,20">
                <Button Style="{DynamicResource MaterialDesignToolButton}"
                        materialDesign:RippleAssist.IsDisabled="True"
                        Width="32" Height="32"
                        ToolTip="Create new playlist"
                        Click="CreatePlaylist_Click">
                    <materialDesign:PackIcon Kind="PlusBox" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource MaterialDesignToolButton}"
                        materialDesign:RippleAssist.IsDisabled="True"
                        Width="32" Height="32"
                        Margin="8,0,0,0"
                        ToolTip="Delete selected playlist"
                        Click="DeletePlaylist_Click">
                    <materialDesign:PackIcon Kind="MinusBox" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource MaterialDesignToolButton}"
                        materialDesign:RippleAssist.IsDisabled="True"
                        Width="32" Height="32"
                        Margin="8,0,0,0"
                        ToolTip="Import playlist from .m3u"
                        Click="ImportPlaylist_Click">
                    <materialDesign:PackIcon Kind="FileImportOutline" Width="20" Height="20"/>
                </Button>
                <Button Style="{DynamicResource MaterialDesignToolButton}"
                        materialDesign:RippleAssist.IsDisabled="True"
                        Width="32" Height="32"
                        Margin="8,0,0,0"
                        ToolTip="Export selected playlist to .m3u"
                        Click="ExportPlaylist_Click">
                    <materialDesign:PackIcon Kind="FileExportOutline" Width="20" Height="20"/>
                </Button>
            </StackPanel>
            <ListView x:Name="lstPlaylists"
                      Grid.Row="2"
                      Background="Transparent"
                      Foreground="{StaticResource TextPrimary-brush}"
                      Padding="{StaticResource Zero-thk}"
                      ItemContainerStyle="{StaticResource SidebarListViewItemStyle}"
                      SelectionChanged="LstPlaylists_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{DynamicResource MaterialDesignToolButton}"
                                    materialDesign:RippleAssist.IsDisabled="True"
                                    Width="24" Height="24"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0"
                                    ToolTip="Pin playlist"
                                    Click="PlaylistPinToggle_Click">
                                <materialDesign:PackIcon Kind="{Binding IsPinned, Converter={StaticResource PinnedToStarIconKindConverter}}"
                                                         Width="16" Height="16"
                                                         Foreground="White"/>
                            </Button>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <!-- Draggable divider matching main splitter -->
        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Style="{StaticResource CustomGridSplitter}"
                      Cursor="SizeWE"
                      ShowsPreview="False"
                      ResizeDirection="Columns"/>
        <Grid Grid.Column="2">
            <views:TrackListView x:Name="trackList"
                                  ViewName="Songs"
                                  SingleClickPlays="False"
                                  PlayTrackRequested="TrackList_PlayTrackRequested"
                                  Visibility="Collapsed"/>
            <TextBlock x:Name="placeholderText"
                       Text="Select a playlist"
                       Foreground="{StaticResource TextMuted-brush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>
