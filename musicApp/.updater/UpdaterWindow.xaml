<Window x:Class="musicApp.Updater.UpdaterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="musicApp - Update"
        Width="420"
        Height="248"
        MinWidth="340"
        MinHeight="200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackground-brush}">
    <Border Padding="{StaticResource Uniform20-thk}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText"
                           Text="Checking for updates…"
                           Style="{StaticResource UpdaterStatusTextStyle}" />
                <ProgressBar x:Name="Progress"
                             Margin="{StaticResource Top10-thk}"
                             Style="{StaticResource UpdaterProgressBarStyle}"
                             IsIndeterminate="True" />
                <StackPanel x:Name="ActionRow"
                            Margin="{StaticResource Top10-thk}"
                            Visibility="Collapsed">
                    <CheckBox x:Name="AutoInstallCheckBox"
                              Margin="{StaticResource Bottom8-thk}"
                              Content="Install updates automatically"
                              Foreground="{StaticResource TextPrimary-brush}"
                              Checked="AutoInstallCheckBox_Changed"
                              Unchecked="AutoInstallCheckBox_Changed" />
                    <CheckBox x:Name="LaunchAfterUpdateCheckBox"
                              Content="Launch musicApp after updating"
                              Foreground="{StaticResource TextPrimary-brush}"
                              Checked="LaunchAfterUpdateCheckBox_Changed"
                              Unchecked="LaunchAfterUpdateCheckBox_Changed" />
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" Margin="{StaticResource Top10-thk}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="AutoCloseCountdownText"
                           Grid.Column="0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Style="{StaticResource UpdaterAutoCloseCountdownStyle}"
                           Visibility="Collapsed" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="UpdateButton"
                            Content="Update now"
                            Margin="{StaticResource Right8-thk}"
                            Style="{StaticResource UpdaterPrimaryButtonStyle}"
                            Visibility="Collapsed"
                            IsDefault="True"
                            Click="UpdateButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Style="{StaticResource UpdaterFooterButtonStyle}"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
