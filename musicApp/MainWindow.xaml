<Window x:Class="musicApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:musicApp"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:titleBar="clr-namespace:musicApp.TitleBarPlus"
        xmlns:converters="clr-namespace:musicApp.Converters"
        xmlns:views="clr-namespace:musicApp.Views"
        xmlns:ui="clr-namespace:musicApp.Constants"
        mc:Ignorable="d"
        Title="musicApp" Height="767" Width="1245"
        Background="{StaticResource AppBackground-brush}"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        MinWidth="1000" MinHeight="500">

    <!-- Remove white bar on top of window-->
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0"/>
    </WindowChrome.WindowChrome>

    <!-- ===========================================
         WINDOW RESOURCES
         =========================================== -->
    <Window.Resources>
        <ResourceDictionary>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <!-- Material Design Theme and Custom Styles -->
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Purple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <!-- Merged last so our ScrollBar style (and 1px content/scrollbar divider) is applied -->
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- ===========================================
         MAIN WINDOW LAYOUT
         =========================================== -->
    <Border BorderBrush="{StaticResource BorderDefault-brush}" BorderThickness="{StaticResource Border1-thk}" Background="{StaticResource AppBackground-brush}">
        <Grid Background="{StaticResource AppBackground-brush}">
            <!-- Main Grid Definitions -->
            <Grid.RowDefinitions>
                <RowDefinition Height="85"/>
                <!-- Title Bar Row -->
                <RowDefinition Height="*"/>
                <!-- Main Content Row -->
                <RowDefinition Height="Auto"/>
                <!-- Status Bar Row -->
            </Grid.RowDefinitions>

            <!-- ===========================================
                 TITLE BAR SECTION
                 =========================================== -->
            <titleBar:TitleBar x:Name="titleBarPlayer" Grid.Row="0"/>

            <!-- Search results popup (placement target set in code) -->
            <Popup x:Name="searchPopup"
                   StaysOpen="False"
                   Placement="Bottom"
                   VerticalOffset="{x:Static ui:UILayoutConstants.SearchPopupTitleBarVerticalOffset}"
                   HorizontalOffset="{x:Static ui:UILayoutConstants.SearchPopupHorizontalOffsetNudge}"
                   AllowsTransparency="True">
                <views:SearchPopupView x:Name="searchPopupView"/>
            </Popup>

            <Popup x:Name="queuePopup"
                   StaysOpen="False"
                   Placement="Bottom"
                   VerticalOffset="{x:Static ui:UILayoutConstants.CompactPopupTitleBarVerticalOffset}"
                   AllowsTransparency="True">
                <views:QueuePopupView x:Name="queuePopupView"/>
            </Popup>

            <!-- ===========================================
                 MAIN CONTENT AREA
                 Contains: Sidebar Navigation + Content Views
                 =========================================== -->
            <Grid Grid.Row="1" x:Name="mainContentGrid">
                <!-- Main Content Grid Definitions -->
                <Grid.ColumnDefinitions>
                    <!-- Width/MinWidth must match UILayoutConstants.SidebarMinWidth (GridLength rejects x:Static double). -->
                    <ColumnDefinition x:Name="sidebarColumn" Width="180" MinWidth="180" MaxWidth="500"/>
                    <!-- Sidebar Width (Resizable) -->
                    <ColumnDefinition Width="5"/>
                    <!-- GridSplitter Column -->
                    <ColumnDefinition Width="*"/>
                    <!-- Content Area (Expands) -->
                </Grid.ColumnDefinitions>

                <!-- ===========================================
                     SIDEBAR NAVIGATION SECTION
                     =========================================== -->
                <Border Grid.Column="0" 
                        Background="{StaticResource PanelBackground-brush}"
                        BorderBrush="{StaticResource BorderDefault-brush}"
                        BorderThickness="0">
                    <StackPanel Margin="0,10,0,10">

                        <!-- App Title -->
                        <TextBlock Text="musicApp" 
                                   FontSize="20" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimary-brush}"
                                   Margin="10,0,10,20"/>

                        <!-- Navigation Buttons -->
                        <Button x:Name="btnArtists" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnArtists_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountMusic" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Artists" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnAlbums" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnAlbums_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Album" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Albums" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnLibrary" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnLibrary_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Music" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Songs" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnGenres" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnGenres_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="MusicNote" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Genres" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnPlaylists" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnPlaylists_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlaylistMusic" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Playlists" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Separator Margin="{StaticResource SeparatorVerticalGap-thk}" Background="{StaticResource BorderDefault-brush}"/>

                        <Button x:Name="btnRecentlyAdded" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnRecentlyAdded_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="LibraryAdd" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Recently Added" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnRecentlyPlayed" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnRecentlyPlayed_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="History" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Recently Played" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnQueue" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnQueue_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="QueueMusic" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Queue" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Pinned playlists (visible only when any playlist is pinned) -->
                        <StackPanel Visibility="{Binding HasPinnedPlaylists, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Separator Margin="{StaticResource SeparatorVerticalGap-thk}" Background="{StaticResource BorderDefault-brush}"/>
                            <ItemsControl ItemsSource="{Binding PinnedPlaylists}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SidebarNavigationButton}"
                                                Click="PinnedPlaylistSidebar_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="PlaylistMusic" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Separator -->
                        <Separator Margin="{StaticResource SeparatorVerticalGap-thk}" Background="{StaticResource BorderDefault-brush}"/>

                        <!-- Action Buttons -->
                        <Button x:Name="btnAddFolder" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnAddFolder_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderPlus" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Add Music" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnRescanLibrary" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnRescanLibrary_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Re-Scan Library" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnRemoveFolder" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnRemoveFolder_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderRemove" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Remove Music" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnClearSettings" 
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnClearSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DeleteSweep" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Clear Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnSettings"
                                Style="{StaticResource SidebarNavigationButton}"
                                Click="BtnSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center" Margin="{StaticResource Right10-thk}"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ===========================================
                     RESIZABLE SPLITTER
                     =========================================== -->
                <GridSplitter Grid.Column="1"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Stretch"
                             Style="{StaticResource CustomGridSplitter}"
                             Cursor="SizeWE"
                             ShowsPreview="False"
                             ResizeDirection="Columns"
                             DragCompleted="GridSplitter_DragCompleted"/>

                <!-- ===========================================
                     MAIN CONTENT VIEWS SECTION
                     =========================================== -->
                <Grid Grid.Column="2" Background="{StaticResource AppBackground-brush}">
                    <!-- Content Views Grid Definitions -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header Row -->
                        <RowDefinition Height="*"/>
                        <!-- Content Row (Expands) -->
                    </Grid.RowDefinitions>

                    <!-- ===========================================
                         CONTENT HEADER SECTION
                         =========================================== -->


                    <!-- ===========================================
                         CONTENT AREA SECTION
                         =========================================== -->
                    <ContentControl Grid.Row="1" x:Name="contentHost" Margin="{StaticResource Zero-thk}"/>
                </Grid>
            </Grid>

            <!-- ===========================================
                 STATUS BAR SECTION
                 =========================================== -->
            <Border Grid.Row="2" 
                    Background="{StaticResource PanelBackground-brush}"
                    BorderBrush="{StaticResource BorderDefault-brush}"
                    BorderThickness="0,1,0,0"
                    Height="20"
                    VerticalAlignment="Bottom">
                <Grid>
                    <!-- Progress Bar Background (integrated) -->
                    <Border x:Name="progressBarBackground"
                            Background="{StaticResource PanelBackground-brush}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"/>

                    <!-- Progress Bar Fill -->
                    <Border x:Name="progressBarFill"
                            Background="{StaticResource ThemeBrand-brush}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Width="0"/>

                    <!-- Status Text (on top of progress bar) -->
                    <TextBlock x:Name="statusBarText" 
                               Text="0 songs, 0 albums, 0.0 days, 0.00 GB" 
                               Foreground="{StaticResource TextPrimary-brush}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Panel.ZIndex="1"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
